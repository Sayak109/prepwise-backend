    "@types/node": "^22.19.17",
    "@types/nodemailer": "^6.4.23",
    "@types/number-to-words": "^1.2.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
